  "srcDir": "src/components/ui",
  "tsconfig": "jsconfig.json",
  "cssEntry": ".design-sync/.cache/compiled-tailwind.css",
  "buildCmd": "npx tailwindcss -i src/index.css -o .design-sync/.cache/compiled-tailwind.css --config tailwind.config.js",
