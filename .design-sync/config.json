  "readmeHeader": ".design-sync/conventions.md",
  "libOverrides": {
    "source-kit.mjs": "drops sonner.jsx from the src scan (unused duplicate Toaster export colliding with toaster.jsx, the one actually mounted in App.jsx)"
  },
  "dtsPropsFor": {
    "Button": "variant?: 'default' | 'destructive' | 'outline' | 'secondary' | 'ghost' | 'link'; size?: 'default' | 'sm' | 'lg' | 'icon'; asChild?: boolean; children?: React.ReactNode; className?: string; disabled?: boolean; onClick?: (e: React.MouseEvent) => void;",
    "Card": "children?: React.ReactNode; className?: string;",
    "Dialog": "open?: boolean; defaultOpen?: boolean; onOpenChange?: (open: boolean) => void; modal?: boolean; children?: React.ReactNode;"
  },
  "overrides": {
    "Dialog": {"cardMode": "single", "viewport": "500x360"},
    "Button": {"cardMode": "column"},
    "Popover": {"cardMode": "single", "viewport": "400x280"},
    "Tooltip": {"cardMode": "single", "viewport": "400x200"},
    "DropdownMenu": {"cardMode": "single", "viewport": "400x320"},
